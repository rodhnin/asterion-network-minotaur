        {% set diff = report.diff %}
        <div style="margin:0 0 38px 0;padding:28px;border-radius:8px;border:2px solid var(--border);background:var(--mino-bg);">
            <h2 style="font-size:22px;margin-bottom:6px;color:var(--mino-dark);">📈 Scan Comparison</h2>
            <p style="font-size:13px;color:var(--text-light);margin-bottom:{% if diff.mode_mismatch %}12{% else %}20{% endif %}px;">
                Compared against scan #{{ diff.ref_scan_id }}
                {% if diff.ref_date %} &mdash; {{ diff.ref_date[:10] }}{% endif %}
                {% if diff.ref_target %} &mdash; {{ diff.ref_target }}{% endif %}
                {% if diff.ref_mode %} &mdash; <strong>{{ diff.ref_mode }} mode</strong>{% endif %}
            </p>

            {% if diff.mode_mismatch %}
            <div style="margin-bottom:20px;padding:12px 16px;border-radius:6px;background:#fff8e1;border:1px solid #ffe082;display:flex;align-items:flex-start;gap:10px;">
                <span style="font-size:18px;line-height:1.4;">⚠️</span>
                <div>
                    <strong style="color:#e65100;font-size:13px;">Mode mismatch: {{ diff.ref_mode }} vs {{ diff.current_mode }}</strong>
                    <p style="margin:4px 0 0;font-size:12px;color:var(--text-light);line-height:1.5;">
                        Reference scan ran in <strong>{{ diff.ref_mode }}</strong> mode, current in <strong>{{ diff.current_mode }}</strong> mode.
                        Differences may reflect checks exclusive to one mode — verify manually before marking issues as resolved.
                    </p>
                </div>
            </div>
            {% endif %}

            <div style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:20px;">
                <div style="flex:1;min-width:130px;padding:14px 18px;border-radius:6px;background:#fff3f3;border:1px solid #f5c6cb;text-align:center;">
                    <div style="font-size:28px;font-weight:700;color:var(--critical);">{{ diff.new | length }}</div>
                    <div style="font-size:12px;font-weight:600;color:var(--critical);text-transform:uppercase;letter-spacing:0.5px;">New</div>
                    <div style="font-size:11px;color:var(--text-light);margin-top:2px;">appeared since last scan</div>
                </div>
                <div style="flex:1;min-width:130px;padding:14px 18px;border-radius:6px;background:#f0fff4;border:1px solid #c3e6cb;text-align:center;">
                    <div style="font-size:28px;font-weight:700;color:#28a745;">{{ diff.fixed | length }}</div>
                    <div style="font-size:12px;font-weight:600;color:#28a745;text-transform:uppercase;letter-spacing:0.5px;">Fixed</div>
                    <div style="font-size:11px;color:var(--text-light);margin-top:2px;">remediated since last scan</div>
                </div>
                <div style="flex:1;min-width:130px;padding:14px 18px;border-radius:6px;background:#f5f5f5;border:1px solid #dee2e6;text-align:center;">
                    <div style="font-size:28px;font-weight:700;color:var(--text-light);">{{ diff.persisting | length }}</div>
                    <div style="font-size:12px;font-weight:600;color:var(--text-light);text-transform:uppercase;letter-spacing:0.5px;">Persisting</div>
                    <div style="font-size:11px;color:var(--text-light);margin-top:2px;">present in both scans</div>
                </div>
            </div>

            {% macro sev_badge(sev) %}
            <span style="display:inline-block;padding:2px 7px;border-radius:3px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;white-space:nowrap;
                background:{% if sev=='critical' %}#dc3545{% elif sev=='high' %}#fd7e14{% elif sev=='medium' %}#ffc107{% elif sev=='low' %}#17a2b8{% else %}#6c757d{% endif %};
                color:{% if sev=='medium' %}#212529{% else %}#fff{% endif %};">{{ sev }}</span>
            {% endmacro %}

            {% if diff.new %}
            <h3 style="font-size:13px;font-weight:700;color:var(--critical);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.5px;">🔴 New findings ({{ diff.new | length }})</h3>
            <table style="width:100%;border-collapse:collapse;margin-bottom:18px;font-size:13px;">
                <thead><tr style="background:#fff3f3;border-bottom:2px solid #f5c6cb;">
                    <th style="padding:8px 12px;text-align:left;color:var(--text-light);font-weight:600;width:15%;">ID</th>
                    <th style="padding:8px 12px;text-align:left;color:var(--text-light);font-weight:600;">Title</th>
                    <th style="padding:8px 12px;text-align:left;color:var(--text-light);font-weight:600;width:12%;">Severity</th>
                </tr></thead>
                <tbody>
                {% for f in diff.new %}
                <tr style="border-bottom:1px solid #f5c6cb;">
                    <td style="padding:7px 12px;font-family:monospace;color:var(--critical);font-size:11px;">{{ f.id }}</td>
                    <td style="padding:7px 12px;">{{ f.title }}</td>
                    <td style="padding:7px 12px;">{{ sev_badge(f.severity) }}</td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
            {% endif %}

            {% if diff.fixed %}
            <h3 style="font-size:13px;font-weight:700;color:#28a745;margin-bottom:8px;text-transform:uppercase;letter-spacing:0.5px;">✅ Fixed findings ({{ diff.fixed | length }})</h3>
            <table style="width:100%;border-collapse:collapse;margin-bottom:18px;font-size:13px;">
                <thead><tr style="background:#f0fff4;border-bottom:2px solid #c3e6cb;">
                    <th style="padding:8px 12px;text-align:left;color:var(--text-light);font-weight:600;width:15%;">ID</th>
                    <th style="padding:8px 12px;text-align:left;color:var(--text-light);font-weight:600;">Title</th>
                    <th style="padding:8px 12px;text-align:left;color:var(--text-light);font-weight:600;width:12%;">Severity</th>
                </tr></thead>
                <tbody>
                {% for f in diff.fixed %}
                <tr style="border-bottom:1px solid #c3e6cb;text-decoration:line-through;opacity:0.7;">
                    <td style="padding:7px 12px;font-family:monospace;color:#28a745;font-size:11px;">{{ f.id }}</td>
                    <td style="padding:7px 12px;">{{ f.title }}</td>
                    <td style="padding:7px 12px;">{{ sev_badge(f.severity) }}</td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
            {% endif %}

            {% if diff.persisting %}
            <details>
                <summary style="font-size:13px;font-weight:600;color:var(--text-light);cursor:pointer;margin-bottom:8px;user-select:none;">
                    ⏳ Persisting findings ({{ diff.persisting | length }}) — click to expand
                </summary>
                <table style="width:100%;border-collapse:collapse;margin-top:8px;font-size:13px;">
                    <thead><tr style="background:#f5f5f5;border-bottom:2px solid #dee2e6;">
                        <th style="padding:8px 12px;text-align:left;color:var(--text-light);font-weight:600;width:15%;">ID</th>
                        <th style="padding:8px 12px;text-align:left;color:var(--text-light);font-weight:600;">Title</th>
                        <th style="padding:8px 12px;text-align:left;color:var(--text-light);font-weight:600;width:12%;">Severity</th>
                    </tr></thead>
                    <tbody>
                    {% for f in diff.persisting %}
                    <tr style="border-bottom:1px solid #dee2e6;">
                        <td style="padding:7px 12px;font-family:monospace;color:var(--text-light);font-size:11px;">{{ f.id }}</td>
                        <td style="padding:7px 12px;color:var(--text-light);">{{ f.title }}</td>
                        <td style="padding:7px 12px;">{{ sev_badge(f.severity) }}</td>
                    </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </details>
            {% endif %}
        </div>
        {% endif %}

        <!-- NOTES -->
        {% if report.notes %}
        <div class="notes">
            <h2>📝 Scan Notes</h2>
            <table>
                {% if report.notes.scan_duration_seconds %}
                <tr><td style="width:30%;font-weight:600;">⏱️ Duration</td><td>{{ report.notes.scan_duration_seconds }} seconds</td></tr>
                {% endif %}
                {% if report.notes.requests_sent %}
                <tr><td style="font-weight:600;">📡 Checks performed</td><td>{{ report.notes.requests_sent }}</td></tr>
                {% endif %}
                {% if report.notes.scope_limitations %}
                <tr><td style="font-weight:600;">🔍 Scope</td><td>{{ report.notes.scope_limitations }}</td></tr>
                {% endif %}
                {% if report.notes.false_positive_disclaimer %}
                <tr><td style="font-weight:600;">⚠️ Disclaimer</td><td>{{ report.notes.false_positive_disclaimer }}</td></tr>
                {% endif %}
            </table>
        </div>
        {% endif %}

    </div><!-- /.content -->

    <!-- FOOTER -->
    <footer>
        <p><strong>Asterion Network Security Auditor</strong> — Navigating the Network Labyrinth 🐂</p>
        <p style="margin-top:12px;">Part of the <strong>Argos Security Suite</strong> | Generated on {{ report.date | datetime }}</p>
        <p style="margin-top:18px;font-size:12px;opacity:0.8;">
            © 2025–2026 <a href="https://github.com/rodhnin" target="_blank">Rodney Dhavid Jimenez Chacin (rodhnin)</a> — MIT License<br>
            <a href="https://github.com/rodhnin/asterion-network-minotaur" target="_blank">GitHub: asterion-network-minotaur</a>
        </p>
        <p style="margin-top:14px;font-size:12px;">
            ⚠️ {{ report.notes.false_positive_disclaimer if report.notes and report.notes.false_positive_disclaimer else 'Manual verification recommended for all findings before remediation. Use only on authorized targets.' }}
        </p>
    </footer>

</div><!-- /.container -->

<!-- JAVASCRIPT -->
<script>
    // ── AI analysis tabs ──────────────────────────────────────────────────────
    function showAiTab(tab, btn) {
        document.querySelectorAll('.ai-content').forEach(el => el.classList.remove('active'));
        document.querySelectorAll('.ai-tab').forEach(el => el.classList.remove('active'));
        const el = document.getElementById(tab + '-tab');
        if (el) el.classList.add('active');
        if (btn) btn.classList.add('active');
    }

    // ── Dual filter: severity + category ─────────────────────────────────────
    var _activeSev = 'all';
    var _activeCat = 'all';

    function filterFindings(type, val, btn) {
        if (type === 'sev') {
            _activeSev = val;
            document.querySelectorAll('.filter-btn:not(.f-cat)').forEach(b => b.classList.remove('active'));
        } else {
            _activeCat = val;
            document.querySelectorAll('.filter-btn.f-cat').forEach(b => b.classList.remove('active'));
        }
        btn.classList.add('active');
        document.querySelectorAll('#findings tbody tr').forEach(row => {
            var sevOk = _activeSev === 'all' || row.dataset.severity === _activeSev;
            var catOk = _activeCat === 'all' || row.dataset.category === _activeCat;
            row.style.display = (sevOk && catOk) ? '' : 'none';
        });
    }

    // ── Expandable panels (CVE list / config snippets) ────────────────────────
    function togglePanel(id) {
        const panel = document.getElementById(id);
        const btn   = panel.previousElementSibling;
        const open  = panel.style.display === 'block';
        panel.style.display = open ? 'none' : 'block';
        if (btn) btn.classList.toggle('open', !open);
    }

    // ── Expandable recommendation ─────────────────────────────────────────────
    function toggleRec(btn) {
        const c  = btn.parentElement;
        const sh = c.querySelector('.rec-short');
        const fu = c.querySelector('.rec-full');
        const open = fu.style.display === 'block';
        if (sh) sh.style.display = open ? 'block' : 'none';
        if (fu) fu.style.display = open ? 'none'  : 'block';
        btn.textContent = open ? 'Show more ▼' : 'Show less ▲';
    }

    // ── Print shortcut ────────────────────────────────────────────────────────
    window.addEventListener('keydown', function(e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'p') { window.print(); }
    });
</script>
</body>
</html>
