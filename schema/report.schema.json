{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://argos-suite.local/schemas/report.schema.json",
    "title": "Argos Suite Security Report",
    "description": "Unified security report schema for Argos, Hephaestus, Pythia, and Asterion",
    "type": "object",
    "required": ["tool", "version", "target", "date", "mode", "summary", "findings"],
    "properties": {
        "tool": {
            "type": "string",
            "enum": ["argus", "hephaestus", "pythia", "asterion"],
            "description": "Tool that generated this report"
        },
        "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Tool version (semantic versioning)"
        },
        "target": {
            "type": "string",
            "description": "Target URL, IP, CIDR range, or domain scanned"
        },
        "date": {
            "type": "string",
            "format": "date-time",
            "description": "Scan completion timestamp (ISO 8601 UTC)"
        },
        "mode": {
            "type": "string",
            "enum": ["safe", "aggressive", "local", "remote", "ssh", "mixed"],
            "description": "Scan mode: safe/aggressive (shared Argos Suite) or local/remote/ssh/mixed (Asterion)"
        },
        "summary": {
            "type": "object",
            "required": ["critical", "high", "medium", "low", "info"],
            "properties": {
                "critical": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Count of critical severity findings"
                },
                "high": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Count of high severity findings"
                },
                "medium": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Count of medium severity findings"
                },
                "low": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Count of low severity findings"
                },
                "info": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Count of informational findings"
                }
            },
            "description": "Count of findings by severity level"
        },
        "riskScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 10,
            "description": "Aggregate risk score 0-10 computed from finding severities"
        },
        "riskLabel": {
            "type": "string",
            "enum": ["Critical Risk", "High Risk", "Medium Risk", "Low Risk", "Minimal Risk", "Secure"],
            "description": "Human-readable risk label derived from riskScore"
        },
        "findings": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/finding"
            },
            "description": "List of security findings/vulnerabilities detected"
        },
        "notes": {
            "type": "object",
            "properties": {
                "scan_duration_seconds": {
                    "type": "number",
                    "minimum": 0,
                    "description": "Total scan duration in seconds"
                },
                "requests_sent": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Number of network requests/checks performed"
                },
                "rate_limit_applied": {
                    "type": "boolean",
                    "description": "Whether rate limiting was applied"
                },
                "scope_limitations": {
                    "type": "string",
                    "description": "Any scope restrictions or assumptions made"
                },
                "false_positive_disclaimer": {
                    "type": "string",
                    "description": "Disclaimer about manual verification"
                }
            },
            "description": "Additional scan metadata"
        },
        "consent": {
            "type": "object",
            "required": ["method", "token", "verified_at"],
            "properties": {
                "method": {
                    "type": "string",
                    "enum": ["http", "dns", "ssh"],
                    "description": "Consent verification method used"
                },
                "token": {
                    "type": "string",
                    "pattern": "^verify-[a-f0-9]{16}$",
                    "description": "Consent token that was verified"
                },
                "verified_at": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Timestamp of consent verification"
                },
                "proof": {
                    "type": "string",
                    "description": "Verification proof (URL, DNS record, or file path)"
                }
            },
            "description": "Ownership verification details (if aggressive mode used)"
        },
        "diff": {
            "type": "object",
            "properties": {
                "ref_scan_id":   { "type": "integer", "description": "scan_id of the reference scan" },
                "ref_date":      { "type": "string",  "description": "ISO 8601 date of reference scan" },
                "ref_target":    { "type": "string",  "description": "Target of the reference scan" },
                "ref_mode":      { "type": "string",  "description": "Scan mode of reference scan" },
                "current_mode":  { "type": "string",  "description": "Scan mode of current scan" },
                "mode_mismatch": { "type": "boolean", "description": "True if modes differ between scans" },
                "new":           { "type": "array", "items": { "$ref": "#/definitions/diff_finding" }, "description": "Findings present in current scan but not in reference" },
                "fixed":         { "type": "array", "items": { "$ref": "#/definitions/diff_finding" }, "description": "Findings present in reference but not in current scan" },
                "persisting":    { "type": "array", "items": { "$ref": "#/definitions/diff_finding" }, "description": "Findings present in both scans" }
            },
            "description": "Diff comparison with a previous scan (if --diff was used)"
        },
        "aiAnalysis": {
            "type": "object",
            "properties": {
                "executiveSummary": {
                    "type": "string",
                    "description": "Non-technical summary for stakeholders (markdown)"
                },
                "technicalRemediation": {
                    "type": "string",
                    "description": "Step-by-step technical guidance for engineers (markdown)"
                },
                "generatedAt": {
                    "type": "string",
                    "format": "date-time",
                    "description": "AI generation timestamp"
                },
                "modelUsed": {
                    "type": "string",
                    "description": "AI model identifier (e.g., gpt-4o-mini-2024-07-18)"
                },
                "tone": { "type": "string" },
                "agentAnalysis": {
                    "type": "string",
                    "description": "Agent-mode NVD-enriched analysis (if --ai-agent)"
                },
                "compareResults": {
                    "type": "object",
                    "description": "Multi-provider comparison results (if --ai-compare)"
                },
                "cost": {
                    "type": "object",
                    "properties": {
                        "total_usd": { "type": "number" },
                        "provider":  { "type": "string" },
                        "model":     { "type": "string" }
                    },
                    "description": "Token usage and cost (IMPROV-005)"
                }
            },
            "description": "AI-generated summaries (if --use-ai enabled)"
        },
        "attackChains": {
            "type": "array",
            "items": { "$ref": "#/definitions/attack_chain" },
            "description": "Correlated attack chains — multi-step attack vectors from co-existing findings"
        }
    },
    "definitions": {
        "finding": {
            "type": "object",
            "required": ["id", "title", "severity", "confidence", "recommendation"],
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^[A-Z]{2,4}(-[A-Z0-9]{2,6}){1,3}-\\d{3}$",
                    "description": "Unique finding identifier (e.g., AST-SMB-001, AST-PRIV-LNX-006, AST-REG-WIN-012)"
                },
                "title": {
                    "type": "string",
                    "minLength": 5,
                    "maxLength": 200,
                    "description": "Brief finding title"
                },
                "description": {
                    "type": "string",
                    "description": "Detailed explanation of the vulnerability"
                },
                "severity": {
                    "type": "string",
                    "enum": ["critical", "high", "medium", "low", "info"],
                    "description": "Severity level"
                },
                "confidence": {
                    "type": "string",
                    "enum": ["high", "medium", "low"],
                    "description": "Confidence in the finding (likelihood of false positive)"
                },
                "evidence": {
                    "type": "object",
                    "description": "Supporting evidence for the finding",
                    "required": ["type", "value"],
                    "properties": {
                        "type": {
                            "type": "string",
                            "enum": [
                                "url", "header", "body", "path", "port",
                                "share", "service", "config", "screenshot",
                                "ldap", "smb", "registry", "ssh", "other"
                            ],
                            "description": "Type of evidence"
                        },
                        "value": {
                            "type": "string",
                            "description": "The actual evidence data"
                        },
                        "context": {
                            "type": "string",
                            "description": "Additional context or explanation"
                        }
                    }
                },
                "recommendation": {
                    "type": "string",
                    "minLength": 10,
                    "description": "Actionable remediation guidance"
                },
                "references": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "format": "uri"
                    },
                    "description": "External reference URLs (documentation, advisories)"
                },
                "cve": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "pattern": "^(CVE-\\d{4}-\\d{4,}|MS\\d{2}-\\d{3})$"
                    },
                    "description": "Related CVE or MS Security Bulletin identifiers"
                },
                "affectedComponent": {
                    "type": "string",
                    "description": "Specific component, service, or host affected"
                },
                "owasp": {
                    "type": "object",
                    "properties": {
                        "id":   { "type": "string", "pattern": "^A\\d{2}$" },
                        "name": { "type": "string" }
                    },
                    "required": ["id", "name"],
                    "description": "OWASP Top 10 2021 category (added by enrichment)"
                },
                "vulnerabilities": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/vulnerability" },
                    "description": "CVE records from NVD (added by cve_lookup enrichment)"
                },
                "cvss": {
                    "type": ["number", "null"],
                    "minimum": 0,
                    "maximum": 10,
                    "description": "Highest CVSS score across linked CVEs (null if no CVEs found)"
                },
                "compliance": {
                    "type": "object",
                    "properties": {
                        "cis":  {
                            "type": "object",
                            "properties": {
                                "id":   { "type": "string" },
                                "name": { "type": "string" }
                            },
                            "required": ["id", "name"]
                        },
                        "nist": {
                            "type": "object",
                            "properties": {
                                "id":   { "type": "string" },
                                "name": { "type": "string" }
                            },
                            "required": ["id", "name"]
                        },
                        "pci":  {
                            "type": "object",
                            "properties": {
                                "id":   { "type": "string" },
                                "name": { "type": "string" }
                            },
                            "required": ["id", "name"]
                        }
                    },
                    "description": "Compliance framework mappings (CIS Controls v8, NIST CSF 2.0, PCI-DSS 4.0)"
                }
            }
        },
        "diff_finding": {
            "type": "object",
            "required": ["id", "title", "severity"],
            "properties": {
                "id":       { "type": "string", "description": "Finding code (e.g. AST-SMB-003)" },
                "title":    { "type": "string" },
                "severity": { "type": "string", "enum": ["critical","high","medium","low","info"] }
            }
        },
        "vulnerability": {
            "type": "object",
            "required": ["cve_id", "title"],
            "properties": {
                "cve_id":        { "type": "string", "pattern": "^CVE-\\d{4}-\\d{4,}$" },
                "title":         { "type": "string" },
                "description":   { "type": "string" },
                "link":          { "type": "string", "format": "uri" },
                "cvss_score":    { "type": "number", "minimum": 0, "maximum": 10 },
                "cvss_severity": { "type": "string", "enum": ["CRITICAL","HIGH","MEDIUM","LOW","NONE"] },
                "cwe_id":        { "type": "string", "pattern": "^CWE-\\d+$" },
                "cwe_name":      { "type": "string" },
                "published":     { "type": "string" }
            }
        },
        "attack_chain": {
            "type": "object",
            "required": ["id", "title", "severity", "mitre", "steps", "findingIds", "remediation"],
            "properties": {
                "id":          { "type": "string", "description": "Chain identifier (e.g., AST-CHAIN-001)" },
                "title":       { "type": "string", "description": "Short title of the attack scenario" },
                "description": { "type": "string", "description": "Narrative explanation of the chained attack" },
                "severity":    { "type": "string", "enum": ["critical","high","medium","low"] },
                "mitre":       { "type": "string", "description": "MITRE ATT&CK technique IDs" },
                "steps":       { "type": "array", "items": { "type": "string" }, "description": "Ordered attack steps" },
                "findingIds":  { "type": "array", "items": { "type": "string" }, "description": "Finding codes that form this chain" },
                "remediation": { "type": "string", "description": "Consolidated remediation guidance" },
                "enhanced":    { "type": "boolean", "description": "True when optional bonus findings are also present" }
            }
        }
    }
}
